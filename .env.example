# Salin file ini sesuai environment: .env.development / .env.staging / .env.production
# Nilai EXPO_PUBLIC_* akan di-bundle ke dalam aplikasi (bukan secret)

# Environment aktif: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Base URL untuk API backend
EXPO_PUBLIC_API_URL=https://your-api-url.com

# Aktifkan Sentry error tracking (true/false)
EXPO_PUBLIC_SENTRY=false
